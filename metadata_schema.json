{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "nome_dataset": { "type": "string" },
    "fonte": { "type": "string" },
    "descricao": { "type": "string" },
    "campos_principais": {
      "type": "array",
      "items": { "type": "string" }
    },
    "data_criacao": { "type": "string", "format": "date" },
    "observacoes": { "type": "string" }
  },
  "required": ["nome_dataset", "fonte", "descricao", "campos_principais", "data_criacao"]
}